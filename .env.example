APP_ENV=development

MYSQL_DATABASE=gestao_clinica
MYSQL_USER=gestao_app
MYSQL_PASSWORD=gestao_app_password
MYSQL_ROOT_PASSWORD=root_password

BACKEND_PORT=3000
FRONTEND_PORT=5173

SESSION_SECRET=change-me-in-development

# Gere uma chave forte com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=replace-with-32-byte-base64-key
APP_HASH_KEY=replace-with-hmac-secret
SESSION_TTL_HOURS=8
